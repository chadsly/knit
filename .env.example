# Knit secrets and env-only overrides
# Copy this to .env if you want shell-managed secrets while keeping knit.toml non-secret.

# Optional override for the generated config location.
# KNIT_CONFIG_PATH=/absolute/path/to/knit.toml

# Remote submit providers
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_ORG_ID=
OPENAI_PROJECT_ID=
CODEX_MODEL=

ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
KNIT_CLAUDE_API_MODEL=

# Remote transcription
OPENAI_STT_MODEL=

# Optional outbound policy overrides
# KNIT_OUTBOUND_ALLOWLIST=api.openai.com,api.anthropic.com
# KNIT_OUTBOUND_BLOCKLIST=
# KNIT_ALLOWED_SUBMIT_PROVIDERS=codex_cli,claude_cli,opencode_cli,codex_api,claude_api

# Optional local runtime overrides
# KNIT_ADDR=127.0.0.1:7777
# KNIT_DATA_DIR=./.knit
# KNIT_SQLITE_PATH=knit.db
# KNIT_AUTO_START=0

# Optional operator auth and encryption
# KNIT_CONTROL_TOKEN=
# KNIT_CONTROL_CAPABILITIES=capture,submit,config,purge,read
# KNIT_ENCRYPTION_KEY_B64=
