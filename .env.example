# Knit secrets and env-only overrides
# Copy this to .env if you want shell-managed secrets while keeping knit.toml non-secret.

# Optional override for the generated config location.
# KNIT_CONFIG_PATH=/absolute/path/to/knit.toml

# Remote submit providers
# OpenAI/Codex API submit example:
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com
# OPENAI_ORG_ID=org_123example
# OPENAI_PROJECT_ID=proj_123example
# CODEX_MODEL=gpt-5-codex
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_ORG_ID=
OPENAI_PROJECT_ID=
CODEX_MODEL=

# Anthropic submit example:
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# KNIT_CLAUDE_API_MODEL=claude-3-7-sonnet-latest
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=
KNIT_CLAUDE_API_MODEL=

# Remote transcription
# OpenAI STT example:
# OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_STT_MODEL=

# Optional transcription mode overrides
# KNIT_TRANSCRIPTION_MODE=faster_whisper   # allowed: faster_whisper, local, lmstudio, remote
# KNIT_LOCAL_STT_CMD=python3 scripts/local_stt.py
# KNIT_FASTER_WHISPER_DEVICE=cpu          # examples: cpu, cuda, metal
# KNIT_FASTER_WHISPER_COMPUTE_TYPE=int8   # examples: int8, float16, int8_float16, float32
# KNIT_FASTER_WHISPER_LANGUAGE=en         # examples: en, en-US

# Optional outbound policy overrides
# KNIT_OUTBOUND_ALLOWLIST=api.openai.com,api.anthropic.com
# KNIT_OUTBOUND_BLOCKLIST=
# KNIT_ALLOWED_SUBMIT_PROVIDERS=codex_cli,claude_cli,opencode_cli,codex_api,claude_api

# Optional local runtime overrides
# KNIT_ADDR=127.0.0.1:7777
# KNIT_DATA_DIR=./.knit
# KNIT_SQLITE_PATH=knit.db
# KNIT_AUTO_START=0
# KNIT_DEFAULT_PROVIDER=codex_cli         # allowed: codex_cli, claude_cli, opencode_cli, codex_api, claude_api
# KNIT_SUBMIT_EXECUTION_MODE=series       # allowed: series, parallel
# KNIT_CODEX_SANDBOX=workspace-write      # allowed: read-only, workspace-write, danger-full-access
# KNIT_CODEX_APPROVAL_POLICY=never        # allowed: untrusted, on-request, never
# KNIT_CODEX_REASONING_EFFORT=medium      # common values: low, medium, high

# Optional operator auth and encryption
# KNIT_CONTROL_TOKEN=
# KNIT_CONTROL_CAPABILITIES=capture,submit,config,purge,read
# KNIT_ENCRYPTION_KEY_B64=
